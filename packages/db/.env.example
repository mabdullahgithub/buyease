# Prisma — copy to .env in this folder (or rely on DATABASE_URL in each app’s .env.local)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Super-admin seeder (npm run seed:admin from this package, or npm run db:seed:admin from repo root)
# Password: min 12 chars, lowercase, uppercase, and a digit (same rules as admin UI)
ADMIN_SEED_EMAIL=admin@buyease.app
ADMIN_SEED_PASSWORD=ChangeMeSecure1Aa
