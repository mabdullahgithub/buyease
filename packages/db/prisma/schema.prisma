// Prisma schema for BuyEase
// PostgreSQL (Supabase compatible)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Shopify OAuth sessions (used by apps/merchant)
// ---------------------------------------------------------------------------
model Session {
  id                    String    @id
  shop                  String
  state                 String
  isOnline              Boolean   @default(false)
  scope                 String?
  expires               DateTime?
  accessToken           String
  /// Refresh token for expiring offline tokens (shprt_…)
  refreshToken          String?
  /// When the access token expires (null = non-expiring)
  tokenExpiresAt        DateTime?
  /// When the refresh token expires (90 days from issue)
  refreshTokenExpiresAt DateTime?
  userId                BigInt?
  firstName             String?
  lastName              String?
  email                 String?
  accountOwner          Boolean   @default(false)
  locale                String?
  collaborator          Boolean?  @default(false)
  emailVerified         Boolean?  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

// ---------------------------------------------------------------------------
// Merchants — one row per installed Shopify store
// ---------------------------------------------------------------------------
model Merchant {
  id                    String    @id @default(cuid())
  shop                  String    @unique
  installedAt           DateTime  @default(now())
  isActive              Boolean   @default(true)
  uninstalledAt         DateTime?
  accessToken           String?
  /// Refresh token for expiring offline tokens (shprt_…)
  refreshToken          String?
  /// When the access token expires (null = non-expiring)
  tokenExpiresAt        DateTime?
  /// When the refresh token expires (90 days from issue)
  refreshTokenExpiresAt DateTime?
  scopes                String?
  planBillingId         String?
  billingCycleStart     DateTime  @default(now())
  ordersThisCycle       Int       @default(0)

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  orders            Order[]
  settings          MerchantSettings?
  buyButtonConfig   BuyButtonConfig?
  formDesignConfig  FormDesignConfig?
  shippingRates     ShippingRate[]
  whatsAppConfig          MerchantWhatsAppConfig?
  googleSheetsIntegration GoogleSheetsIntegration?
  messagingSettings       MessagingSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([planId])
  @@index([isActive])
}

// ---------------------------------------------------------------------------
// WhatsAppGlobalConfig — singleton (id=1) controlled by admin panel.
// Holds the shared Twilio credentials and per-message price for all merchants.
// ---------------------------------------------------------------------------
model WhatsAppGlobalConfig {
  id           Int              @id @default(1)
  provider     WhatsAppProvider @default(TWILIO)
  /// Twilio: Account SID (ACxxxxxx…) | Meta: not used
  accountSid   String?
  /// Twilio: Auth Token | Meta: System User permanent Access Token
  authToken    String?
  /// Twilio: sender number e.g. whatsapp:+14155238886 | Meta: Phone Number ID
  senderNumber String?
  /// Meta WhatsApp Cloud API only: WhatsApp Business Account ID (WABA ID)
  wabaId       String?
  /// Price charged per outbound message in cents (e.g. 0.5 = $0.005, 5 = $0.05)
  pricePerMessage Decimal       @default(5) @db.Decimal(10, 4)
  isEnabled    Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WhatsAppProvider {
  TWILIO
  WHATSAPP_BUSINESS
}

// ---------------------------------------------------------------------------
// MerchantWhatsAppConfig — per-shop WhatsApp settings.
// Merchants add their recipient number and manage notification toggles.
// Credit balance is topped up by admin or Shopify billing charge.
// ---------------------------------------------------------------------------
model MerchantWhatsAppConfig {
  id       String   @id @default(cuid())
  shop     String   @unique
  merchant Merchant @relation(fields: [shop], references: [shop], onDelete: Cascade)

  isEnabled       Boolean @default(false)
  /// Customer-facing recipient number e.g. +923001234567
  recipientNumber String?
  /// Pre-paid credit balance in cents
  creditBalance   Int     @default(0)

  notifyOrderConfirmed Boolean @default(true)
  notifyOrderShipped   Boolean @default(true)
  notifyOrderDelivered Boolean @default(false)
  notifyAbandonedCart  Boolean @default(false)
  /// Minutes after cart abandonment before sending the WhatsApp recovery message (default 15)
  abandonedCartDelayMinutes Int @default(15)

  messages WhatsAppMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([isEnabled])
}

// ---------------------------------------------------------------------------
// WhatsAppMessage — immutable audit log of every sent/attempted message.
// ---------------------------------------------------------------------------
model WhatsAppMessage {
  id          String                @id @default(cuid())
  shop        String
  config      MerchantWhatsAppConfig @relation(fields: [shop], references: [shop])

  orderId      String?
  messageType  WhatsAppMessageType
  status       WhatsAppMessageStatus @default(PENDING)
  /// Cost deducted from merchant credit balance in cents
  costCents    Int                   @default(0)
  /// Provider message SID (e.g. Twilio SM…) for delivery tracking
  externalId   String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([status])
  @@index([messageType])
  @@index([createdAt])
}

enum WhatsAppMessageType {
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  ABANDONED_CART
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

// ---------------------------------------------------------------------------
// WhatsAppTemplate — admin-managed message templates, one per message type.
// For Meta Cloud API: metaTemplateName must be registered and approved in Meta
// Business Manager before isActive can be set to true.
// For Twilio: body is sent as free-form text; metaTemplateName is unused.
// ---------------------------------------------------------------------------
model WhatsAppTemplate {
  id               String              @id @default(cuid())
  messageType      WhatsAppMessageType @unique
  /// Template name registered in Meta Business Manager (lowercase + underscores only)
  metaTemplateName String?
  /// Message body. Use {{variableName}} placeholders e.g. {{orderId}}, {{shopName}}
  body             String
  /// Ordered variable names available for this template
  variables        String[]
  /// Meta approval status: NONE | PENDING | APPROVED | REJECTED | PAUSED
  metaStatus       String              @default("NONE")
  isActive         Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// MerchantSettings — per-shop configuration persisted from the settings page
// ---------------------------------------------------------------------------
model MerchantSettings {
  id       String   @id @default(cuid())
  shop     String   @unique
  merchant Merchant @relation(fields: [shop], references: [shop], onDelete: Cascade)

  defaultCurrency   String  @default("USD")
  timezone          String  @default("UTC")
  notificationEmail String?
  webhookUrl        String?

  /// Minutes to wait after cart abandonment before creating a draft order / sending recovery (default 15)
  abandonedCartDelayMinutes Int @default(15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

// ---------------------------------------------------------------------------
// BuyButtonConfig — customization settings for the COD buy button on storefront
// ---------------------------------------------------------------------------
model BuyButtonConfig {
  id       String   @id @default(cuid())
  shop     String   @unique
  merchant Merchant @relation(fields: [shop], references: [shop], onDelete: Cascade)

  buttonText     String  @default("Order via COD")
  buttonSubtitle String?
  iconId         String  @default("cart")
  iconAlign      String  @default("start")
  showIcon       Boolean @default(true)
  animation      String  @default("none")

  stickyPosition  String  @default("off")
  stickyMobile    Boolean @default(true)
  mobileFullWidth Boolean @default(false)

  bgColor        String @default("#000000")
  textColor      String @default("#FFFFFF")
  borderColor    String @default("#000000")
  fontSizePx     Int    @default(16)
  borderRadiusPx Int    @default(8)
  borderWidthPx  Int    @default(0)
  shadowStrength Int    @default(0)
  widthPercent   Int    @default(100)

  isBold    Boolean @default(false)
  isItalic  Boolean @default(false)
  isVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([isVisible])
}

// ---------------------------------------------------------------------------
// FormDesignConfig — layout, fields, and styling for the checkout form
// ---------------------------------------------------------------------------
model FormDesignConfig {
  id       String   @id @default(cuid())
  shop     String   @unique
  merchant Merchant @relation(fields: [shop], references: [shop], onDelete: Cascade)

  formType String @default("popup")
  fields   Json   @default("[]")

  formBgColor        String @default("#FFFFFF")
  formTextColor      String @default("#000000")
  formBorderColor    String @default("#E5E5E5")
  formBorderRadiusPx Int    @default(12)
  formPaddingPx      Int    @default(24)

  fieldBgColor        String @default("#FFFFFF")
  fieldTextColor      String @default("#000000")
  fieldBorderColor    String @default("#D1D5DB")
  fieldBorderRadiusPx Int    @default(6)
  fieldFontSizePx     Int    @default(14)

  formBorderWidthPx Int     @default(1)
  formShadowPx      Int     @default(8)
  formTextBold      Boolean @default(false)
  formTextItalic    Boolean @default(false)
  showIcons         Boolean @default(true)
  stickyMobile      Boolean @default(true)

  textAlign    String  @default("left")
  hideLabels   Boolean @default(false)
  rtl          Boolean @default(false)
  autocomplete Boolean @default(true)

  errorRequired String @default("This field is required")
  errorInvalid  String @default("Please enter a valid value")
  errorSoldOut  String @default("This product is sold out")

  isVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([isVisible])
}

// ---------------------------------------------------------------------------
// ShippingRate — configurable shipping options displayed in the checkout form
// ---------------------------------------------------------------------------
model ShippingRate {
  id       String   @id @default(cuid())
  shop     String
  merchant Merchant @relation(fields: [shop], references: [shop], onDelete: Cascade)

  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  currency    String  @default("USD")

  conditions Json @default("[]")

  countriesEnabled Boolean @default(false)
  countries        Json    @default("[]")
  provincesEnabled Boolean @default(false)
  provinces        Json    @default("[]")

  importedFromShopify Boolean @default(false)
  isActive            Boolean @default(true)
  sortOrder           Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([isActive])
  @@index([shop, sortOrder])
}

// ---------------------------------------------------------------------------
// Orders — COD orders placed via BuyEase forms
// ---------------------------------------------------------------------------
model Order {
  id            String      @id @default(cuid())
  shopId        String
  merchant      Merchant    @relation(fields: [shopId], references: [shop])
  orderId       String
  codAmount     Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  customerName  String?
  customerPhone String?
  customerEmail String?
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, orderId])
  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ---------------------------------------------------------------------------
// Plans — subscription tiers
// ---------------------------------------------------------------------------
model Plan {
  id       String       @id @default(cuid())
  name     String       @unique
  price    Decimal      @db.Decimal(10, 2)
  interval PlanInterval @default(MONTHLY)
  isActive Boolean      @default(true)
  features Json
  limits   Json

  merchants Merchant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlanInterval {
  MONTHLY
  ANNUAL
}

// ---------------------------------------------------------------------------
// AdminUser — super admin panel users
// ---------------------------------------------------------------------------
model AdminUser {
  id                        String                     @id @default(cuid())
  email                     String                     @unique
  displayName               String?
  profileImage              Bytes?
  profileImageMimeType      String?
  passwordHash              String
  role                      AdminRole                  @default(VIEWER)
  passwordReminderDays      Int                        @default(30)
  twoFactorEnabled          Boolean                    @default(false)
  twoFactorSecretEncrypted  String?
  twoFactorEnabledAt        DateTime?
  lastLoginAt               DateTime?
  isActive                  Boolean                    @default(true)
  loginActivities           AdminLoginActivity[]
  createdIpAllowlistEntries AdminIpAllowlist[]         @relation("AdminIpAllowlistCreatedBy")
  createdIpBlocklistEntries AdminIpBlocklist[]         @relation("AdminIpBlocklistCreatedBy")
  updatedIpAccessSettings   AdminIpAccessSetting[]     @relation("AdminIpAccessSettingUpdatedBy")
  twoFactorRecoveryCodes    AdminTwoFactorBackupCode[]
  trustedDevices            AdminTrustedDevice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Admin password reset (forgot-password flow)
// ---------------------------------------------------------------------------
model AdminPasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([tokenHash])
  @@index([expiresAt])
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum AdminIpAccessMode {
  ALLOW_ALL
  RESTRICTED_ALLOWLIST
}

model AdminIpAllowlist {
  id          String     @id @default(cuid())
  ip          String     @unique
  label       String?
  isActive    Boolean    @default(true)
  createdById String?
  createdBy   AdminUser? @relation("AdminIpAllowlistCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model AdminLoginActivity {
  id              String     @id @default(cuid())
  adminUserId     String?
  adminUser       AdminUser? @relation(fields: [adminUserId], references: [id])
  email           String?
  ip              String
  userAgent       String?
  locationCity    String?
  locationRegion  String?
  locationCountry String?
  successful      Boolean    @default(false)
  failureReason   String?

  createdAt DateTime @default(now())

  @@index([adminUserId])
  @@index([createdAt])
  @@index([ip])
}

model AdminTwoFactorBackupCode {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  codeHash    String    @unique
  usedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([adminUserId])
  @@index([usedAt])
}

model AdminTrustedDevice {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  userAgent   String?
  expiresAt   DateTime
  lastUsedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([adminUserId])
  @@index([expiresAt])
}

model AdminIpBlocklist {
  id          String     @id @default(cuid())
  ip          String     @unique
  label       String?
  isActive    Boolean    @default(true)
  createdById String?
  createdBy   AdminUser? @relation("AdminIpBlocklistCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model AdminIpAccessSetting {
  id            Int               @id
  allowlistMode AdminIpAccessMode @default(RESTRICTED_ALLOWLIST)
  updatedById   String?
  updatedBy     AdminUser?        @relation("AdminIpAccessSettingUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([allowlistMode])
}

// ---------------------------------------------------------------------------
// GoogleSheetsIntegration — per-shop Google Sheets connection and sync config
// ---------------------------------------------------------------------------
model GoogleSheetsIntegration {
  id       String   @id @default(cuid())
  shop     String   @unique
  merchant Merchant @relation(fields: [shop], references: [shop], onDelete: Cascade)

  /// AES-256-CBC encrypted access token
  googleAccessToken    String?
  /// AES-256-CBC encrypted refresh token
  googleRefreshToken   String?
  googleTokenExpiresAt DateTime?
  /// The Google account email that authorised the connection
  googleEmail          String?

  spreadsheetId    String?
  spreadsheetUrl   String?
  sheetName        String  @default("Orders")
  abandonedSheetName String @default("Orders")

  /// Array of field names for column A to AZ (Json array of 52 strings)
  selectedFields   Json?

  singleRowPerOrder Boolean @default(true)
  insertAtTop       Boolean @default(false)
  autoSync          Boolean @default(true)

  layoutDesign      String  @default("Standard")
  importPreset      String  @default("Custom")

  headerRowWritten Boolean @default(false)
  isEnabled        Boolean @default(false)

  lastSyncAt    DateTime?
  lastSyncError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([isEnabled])
}

// ---------------------------------------------------------------------------
// AppSettings — singleton (id=1) for global platform configuration
// Controlled by admin panel. Cached in-memory with short TTL.
// ---------------------------------------------------------------------------
model AppSettings {
  id                    Int     @id @default(1)
  maintenanceEnabled    Boolean @default(false)
  maintenanceMessage    String  @default("BuyEase is undergoing scheduled maintenance. Please try again shortly.")
  maintenanceRetryAfter Int     @default(300)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// MessagingSettings — per-shop SMS & WhatsApp configuration
// ---------------------------------------------------------------------------
model MessagingSettings {
  id       String   @id @default(cuid())
  shop     String   @unique
  merchant Merchant @relation(fields: [shop], references: [shop], onDelete: Cascade)

  channel  String   @default("sms") // "sms" or "whatsapp"
  shopName String   @default("Product Store")

  // Services
  otpActive                Boolean @default(true)
  otpMessage               String  @default("Your verification code is {otp}")
  
  orderConfirmationActive  Boolean @default(false)
  orderConfirmationMessage String  @default("Thanks for your purchase from {shop_name} {order_url}")
  
  shippingConfirmationActive  Boolean @default(false)
  shippingConfirmationMessage String  @default("Your order has been shipped from {shop_name} - Track your order at {tracking_url}")
  
  abandonedCartActive      Boolean @default(false)
  abandonedCartMessage     String  @default("We noticed you left something in your cart at {shop_name}. Don't miss out, finish your purchase today! {recovery_url}")
  abandonedCartAutoOpen    Boolean @default(false)

  // OTP Popup Text
  otpVerificationCode      String  @default("Verify your phone number to complete your order")
  otpDescription           String  @default("We've sent a verification code via {channel} to your phone number {phone}. Please enter the code below to verify your number and complete your order")
  otpVerifyButton          String  @default("Verify")
  otpResend                String  @default("Resend code")
  otpChangeNumber          String  @default("Change number")
  otpInvalidCode           String  @default("The code you entered is invalid.")
  otpCodeSent              String  @default("A new verification code has been sent to your mobile number.")
  otpResentAttempts        String  @default("You've exceeded the maximum number of attempts.")
  otpAskBeforeCreating     Boolean @default(false)
  otpMaxAttempts           String  @default("3")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}
