# BuyEase Merchant App — Environment Variables
# Copy this file to .env.local and fill in values

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/buyease

# ── Shopify App Credentials ─────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SHOPIFY_SCOPES=read_orders,write_orders,read_products,write_products

# ── Dev server ───────────────────────────────────────────────────────────────
PORT=3001

# ── App URL (must be HTTPS for Shopify OAuth in local dev) ──────────────────
# Production: https://app.buyease.app
# Local: run ngrok (or Cloudflare Tunnel) and paste the HTTPS origin here AND
# in Partner Dashboard → App setup → App URL / Allowed redirection URL(s).
SHOPIFY_APP_URL=https://selecting-mask-invitation-deleted.trycloudflare.com
# ── Session Security ────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string-in-production
SHOPIFY_THEME_EXTENSION_ID=d0b0bc95-52e2-296f-eebb-ebf82a926275098d7011