{%- comment -%}
  BuyEase COD Form — app embed
  Note: Theme App Extensions Liquid does NOT expose `app.url`, only `app.metafields`.
  We pass the API base via the block setting (defaults to production) so merchants
  on dev tunnels can override it without rebuilding the extension.
{%- endcomment -%}

{%- assign buyease_api_base = block.settings.api_base | default: 'https://buyease-merchant-4st4.vercel.app' -%}
{%- assign buyease_variant = product.selected_or_first_available_variant -%}
{%- assign buyease_image = buyease_variant.featured_image | default: product.featured_image -%}
{%- if buyease_image -%}
  {%- assign buyease_image_url = buyease_image | image_url: width: 200 -%}
{%- else -%}
  {%- assign buyease_image_url = '' -%}
{%- endif -%}
{%- assign buyease_variant_title = buyease_variant.title | default: '' -%}
{%- if buyease_variant_title == 'Default Title' -%}{%- assign buyease_variant_title = '' -%}{%- endif -%}

{%- comment -%}
  Hide Shopify's dynamic checkout block (Buy it now / Shop Pay / GPay / etc.)
  the instant the page renders — before any JavaScript executes — so visitors
  never see the default button flash and disappear (FOUC). Inlined here, not
  loaded from the JS asset, because the asset has a network round-trip.
{%- endcomment -%}
<style>
  form[action*="/cart/add"] .shopify-payment-button,
  form[action*="/cart/add"] [data-shopify="payment-button"],
  form[action*="/cart/add"] .shopify-payment-button__button,
  form[action*="/cart/add"] .shopify-payment-button__more-options,
  form[action*="/cart/add"] [data-testid="Checkout-button"] {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
  }
</style>

<div
  id="buyease-cod-root"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-product-image="{{ buyease_image_url }}"
  data-variant-id="{{ buyease_variant.id }}"
  data-variant-title="{{ buyease_variant_title | escape }}"
  data-price="{{ buyease_variant.price }}"
  data-currency="{{ shop.currency }}"
  data-country="{{ localization.country.iso_code | default: shop.country_code | default: 'US' }}"
  data-shop="{{ shop.permanent_domain }}"
  data-api-base="{{ buyease_api_base }}"
></div>
<script src="{{ 'cod-form.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "BuyEase COD Form",
  "target": "body",
  "settings": [
    {
      "type": "url",
      "id": "api_base",
      "label": "API base URL (advanced)",
      "info": "Leave empty unless instructed by BuyEase support."
    }
  ]
}
{% endschema %}
