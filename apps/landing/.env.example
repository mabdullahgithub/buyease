# BuyEase Landing — Environment Variables
# Copy this file to .env.local and fill in values

# ── Dev server ───────────────────────────────────────────────────────────────
# Next.js reads PORT from .env.local (or pass: npx next dev -p 4000)
PORT=3000

# ── Analytics (optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Waitlist / CRM (optional) ───────────────────────────────────────────────
NEXT_PUBLIC_CONVERTKIT_FORM_ID=
CONVERTKIT_API_KEY=

# ── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MERCHANT_URL=http://localhost:3001
