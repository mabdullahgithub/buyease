# BuyEase Admin Panel — Environment Variables
# Copy this file to .env.local and fill in values

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/buyease

# ── Dev server ───────────────────────────────────────────────────────────────
PORT=3002

# ── NextAuth v5 ─────────────────────────────────────────────────────────────
AUTH_SECRET=change-this-to-a-long-random-string-in-production
AUTH_URL=http://localhost:3002
NEXTAUTH_URL=http://localhost:3002

# ── IP Allowlist ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed IPs (middleware uses this env var)
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# ── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ── Password reset email (Resend) ───────────────────────────────────────────
# https://resend.com — verify your sending domain, then set:
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
