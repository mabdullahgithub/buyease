{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "ADMIN_SEED_EMAIL",
        "ADMIN_SEED_PASSWORD",
        "AUTH_SECRET",
        "DATABASE_URL",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "SESSION_SECRET",
        "SHOPIFY_API_KEY",
        "SHOPIFY_API_SECRET",
        "SHOPIFY_APP_URL",
        "SHOPIFY_SCOPES"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "../../node_modules/.prisma/**",
        "../../node_modules/@prisma/client/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "generate": {
      "cache": false,
      "outputs": ["node_modules/.prisma/**"]
    }
  }
}
